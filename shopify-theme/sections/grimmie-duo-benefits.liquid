{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subtitle = section.settings.subtitle
  assign product_image = section.settings.product_image
  assign product_image_alt = section.settings.product_image_alt_text
  assign image_width_desktop = section.settings.image_width_desktop
  assign image_width_mobile = section.settings.image_width_mobile
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link

  assign bg_color = section.settings.background_color
  assign heading_color = section.settings.heading_color
  assign text_color = section.settings.text_color
  assign subtitle_color = section.settings.subtitle_color
  assign card_bg_color = section.settings.card_background_color
  assign card_border_color = section.settings.card_border_color
  assign card_title_color = section.settings.card_title_color
  assign accent_color = section.settings.accent_color
  assign icon_color = section.settings.icon_color
  assign btn_bg = section.settings.button_background_color
  assign btn_text = section.settings.button_text_color
  assign btn_hover_bg = section.settings.button_hover_background_color
  assign card_gap = section.settings.card_gap
-%}

<style>
  .grimmie-db-{{ section_id }} {
    --db-bg: {{ bg_color }};
    --db-heading: {{ heading_color }};
    --db-text: {{ text_color }};
    --db-subtitle: {{ subtitle_color }};
    --db-card-bg: {{ card_bg_color }};
    --db-card-border: {{ card_border_color }};
    --db-card-title: {{ card_title_color }};
    --db-accent: {{ accent_color }};
    --db-icon: {{ icon_color }};
    --db-btn-bg: {{ btn_bg }};
    --db-btn-text: {{ btn_text }};
    --db-btn-hover-bg: {{ btn_hover_bg }};
    --db-card-gap: {{ card_gap }}px;

    background-color: var(--db-bg);
    color: var(--db-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .grimmie-db-{{ section_id }} * {
    box-sizing: border-box;
  }

  .grimmie-db-{{ section_id }}__inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 56px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .grimmie-db-{{ section_id }}__header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto clamp(40px, 5vw, 60px);
  }

  .grimmie-db-{{ section_id }}__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: clamp(36px, 5.4vw, 76px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--db-heading);
    margin: 0 0 clamp(18px, 2.2vw, 28px);
  }

  .grimmie-db-{{ section_id }}__subtitle {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.65;
    color: var(--db-subtitle);
    margin: 0 auto;
    max-width: 60ch;
    opacity: 0.95;
  }

  .grimmie-db-{{ section_id }}__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--db-card-gap);
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .grimmie-db-{{ section_id }}__card {
    background-color: var(--db-card-bg);
    border: 1px solid var(--db-card-border);
    border-radius: 18px;
    padding: clamp(36px, 4vw, 56px) clamp(24px, 2.6vw, 36px) clamp(36px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    list-style: none;
  }

  .grimmie-db-{{ section_id }}__badge {
    width: clamp(60px, 5.6vw, 80px);
    height: clamp(60px, 5.6vw, 80px);
    border-radius: 50%;
    background-color: var(--db-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: clamp(22px, 2.6vw, 32px);
    color: var(--db-icon);
  }

  .grimmie-db-{{ section_id }}__badge svg,
  .grimmie-db-{{ section_id }}__badge img {
    width: 44%;
    height: 44%;
    display: block;
  }

  .grimmie-db-{{ section_id }}__badge svg {
    stroke: var(--db-icon);
    fill: none;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .grimmie-db-{{ section_id }}__card-title {
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: clamp(12px, 0.95vw, 14px);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--db-card-title);
    margin: 0 0 clamp(16px, 1.6vw, 22px);
    line-height: 1.4;
  }

  .grimmie-db-{{ section_id }}__card-description {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: clamp(13px, 0.95vw, 15px);
    line-height: 1.6;
    color: var(--db-text);
    margin: 0;
    max-width: 28ch;
    opacity: 0.92;
  }

  .grimmie-db-{{ section_id }}__image-wrap {
    width: 100%;
    max-width: {{ image_width_desktop }}px;
    margin: clamp(20px, 3vw, 40px) auto 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grimmie-db-{{ section_id }}__image-wrap img,
  .grimmie-db-{{ section_id }}__image-wrap svg.placeholder {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: contain;
    display: block;
  }

  .grimmie-db-{{ section_id }}__image-wrap .placeholder {
    color: var(--db-card-border);
    opacity: 0.55;
    aspect-ratio: 16 / 9;
  }

  .grimmie-db-{{ section_id }}__cta-wrap {
    text-align: center;
    margin-top: clamp(28px, 3vw, 44px);
  }

  .grimmie-db-{{ section_id }}__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--db-btn-bg);
    color: var(--db-btn-text);
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 18px clamp(40px, 5vw, 56px);
    text-decoration: none;
    border: none;
    cursor: pointer;
    min-height: 56px;
    border-radius: 4px;
    line-height: 1;
    transition: background-color 0.2s ease, filter 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .grimmie-db-{{ section_id }}__cta:hover {
    background-color: var(--db-btn-hover-bg);
  }

  .grimmie-db-{{ section_id }}__cta:focus-visible {
    outline: 2px solid var(--db-btn-bg);
    outline-offset: 3px;
  }

  /* Tablet */
  @media (max-width: 980px) {
    .grimmie-db-{{ section_id }}__cards {
      gap: clamp(16px, 2vw, 24px);
    }

    .grimmie-db-{{ section_id }}__card {
      padding: clamp(28px, 3.2vw, 40px) 20px;
    }
  }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .grimmie-db-{{ section_id }} {
      padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }

    .grimmie-db-{{ section_id }}__heading {
      font-size: clamp(34px, 11vw, 46px);
      line-height: 1.08;
    }

    .grimmie-db-{{ section_id }}__cards {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .grimmie-db-{{ section_id }}__card {
      padding: 32px 22px;
    }

    .grimmie-db-{{ section_id }}__badge {
      width: 64px;
      height: 64px;
      margin-bottom: 20px;
    }

    .grimmie-db-{{ section_id }}__image-wrap {
      max-width: {{ image_width_mobile }}vw;
      margin-top: 28px;
    }

    .grimmie-db-{{ section_id }}__cta {
      padding: 16px 40px;
      font-size: 11.5px;
      min-height: 50px;
    }
  }
</style>

<section
  class="grimmie-db grimmie-db-{{ section_id }}"
  aria-label="{{ section.settings.aria_label | default: 'Duo benefits' | escape }}"
  {{ section.shopify_attributes }}
>
  <div class="grimmie-db-{{ section_id }}__inner">
    {%- if heading != blank or subtitle != blank -%}
      <header class="grimmie-db-{{ section_id }}__header">
        {%- if heading != blank -%}
          <h2 class="grimmie-db-{{ section_id }}__heading">{{ heading | escape | newline_to_br }}</h2>
        {%- endif -%}
        {%- if subtitle != blank -%}
          <p class="grimmie-db-{{ section_id }}__subtitle">{{ subtitle | escape | newline_to_br }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <ul class="grimmie-db-{{ section_id }}__cards" role="list">
      {%- for block in section.blocks -%}
        <li class="grimmie-db-{{ section_id }}__card" {{ block.shopify_attributes }}>
          <div class="grimmie-db-{{ section_id }}__badge" aria-hidden="{% if block.settings.icon_alt_text == blank %}true{% else %}false{% endif %}">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 120 | image_tag: alt: block.settings.icon_alt_text, loading: 'lazy', widths: '60,120', class: 'db-icon-img' }}
            {%- else -%}
              {%- case block.settings.fallback_icon -%}
                {%- when 'pouch' -%}
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt_text | default: 'Pouch' | escape }}">
                    <rect x="6" y="13" width="16" height="13" rx="2"/>
                    <path d="M10 13 V10 a3 3 0 0 1 3 -3 h2 a3 3 0 0 1 3 3 V13"/>
                    <path d="M22 9 h3 a2 2 0 0 1 2 2 V20 a2 2 0 0 1 -2 2 h-3"/>
                  </svg>
                {%- when 'hairdryer' -%}
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt_text | default: 'Hair dryer' | escape }}">
                    <path d="M5 10 C 5 7 7 5 10 5 H17 a3 3 0 0 1 3 3 V14 a3 3 0 0 1 -3 3 H10 C 7 17 5 15 5 12 Z"/>
                    <path d="M13 17 V22 a3 3 0 0 0 3 3"/>
                    <path d="M21 9 H24 M21 11 H25 M21 13 H24"/>
                    <circle cx="11" cy="11" r="1.6"/>
                  </svg>
                {%- when 'sparkle' -%}
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt_text | default: 'Sparkle' | escape }}">
                    <path d="M16 4 L18 14 L28 16 L18 18 L16 28 L14 18 L4 16 L14 14 Z"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt_text | default: 'Icon' | escape }}">
                    <circle cx="16" cy="16" r="8"/>
                  </svg>
              {%- endcase -%}
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="grimmie-db-{{ section_id }}__card-title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="grimmie-db-{{ section_id }}__card-description">{{ block.settings.description | escape | newline_to_br }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div class="grimmie-db-{{ section_id }}__image-wrap">
      {%- if product_image != blank -%}
        {{ product_image | image_url: width: 1400 | image_tag: alt: product_image_alt, loading: 'lazy', widths: '500,800,1100,1400', sizes: '(max-width: 640px) 90vw, 720px' }}
      {%- else -%}
        <svg class="placeholder" viewBox="0 0 200 112" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <rect x="30" y="40" width="100" height="55" rx="14" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <rect x="120" y="55" width="55" height="40" rx="10" fill="none" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      {%- endif -%}
    </div>

    {%- if cta_text != blank -%}
      <div class="grimmie-db-{{ section_id }}__cta-wrap">
        {%- if cta_link != blank -%}
          <a class="grimmie-db-{{ section_id }}__cta" href="{{ cta_link }}">{{ cta_text | escape }}</a>
        {%- else -%}
          <span class="grimmie-db-{{ section_id }}__cta" role="button" aria-disabled="true">{{ cta_text | escape }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Grimmie Duo Benefits",
  "tag": "section",
  "class": "grimmie-duo-benefits-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Line breaks are preserved.",
      "default": "Perché insieme\nfunzionano meglio"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Organizza tutta la tua routine con stile. Insieme, tengono tutto in ordine e sono bellissimi da esporre sul piano del bagno o sulla tua postazione make-up e skincare."
    },
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image",
      "info": "Centered below the cards. Transparent PNG recommended."
    },
    {
      "type": "text",
      "id": "product_image_alt_text",
      "label": "Image alt text",
      "default": "Alma Duo - Classic and Large pouches"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Image max width (desktop)",
      "min": 320,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "default": 720
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Image max width (mobile)",
      "min": 60,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 92
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "SCOPRI IL DUO"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#F7F1EE"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#3B2A22"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#6E5F59"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Card body text color",
      "default": "#6E5F59"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#F1EBE6"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#E7DDD6"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#3B2A22"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Icon badge background (blush)",
      "default": "#EACBC8"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#3B2A22"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background",
      "default": "#EACBC8"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Button hover background",
      "default": "#DFAFB3"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#6E5F59"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap (desktop)",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Section aria-label",
      "default": "Duo benefits"
    }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Benefit card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (SVG or PNG)",
          "info": "Optional. Leave empty to use a fallback icon."
        },
        {
          "type": "select",
          "id": "fallback_icon",
          "label": "Fallback icon",
          "options": [
            { "value": "pouch", "label": "Pouch / daily essentials" },
            { "value": "hairdryer", "label": "Hair dryer / routine" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "none", "label": "None (circle)" }
          ],
          "default": "pouch"
        },
        {
          "type": "text",
          "id": "icon_alt_text",
          "label": "Icon alt text",
          "info": "Leave blank if decorative."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "UNA PER IL QUOTIDIANO"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Classic è perfetta per gli essenziali di ogni giorno: make-up, skincare e piccoli prodotti sempre a portata di mano."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Grimmie Duo Benefits",
      "category": "Grimmie",
      "settings": {
        "heading": "Perché insieme\nfunzionano meglio",
        "subtitle": "Organizza tutta la tua routine con stile. Insieme, tengono tutto in ordine e sono bellissimi da esporre sul piano del bagno o sulla tua postazione make-up e skincare.",
        "product_image_alt_text": "Alma Duo - Classic and Large pouches",
        "image_width_desktop": 720,
        "image_width_mobile": 92,
        "cta_text": "SCOPRI IL DUO",
        "background_color": "#F7F1EE",
        "heading_color": "#3B2A22",
        "subtitle_color": "#6E5F59",
        "text_color": "#6E5F59",
        "card_background_color": "#F1EBE6",
        "card_border_color": "#E7DDD6",
        "card_title_color": "#3B2A22",
        "accent_color": "#EACBC8",
        "icon_color": "#3B2A22",
        "button_background_color": "#EACBC8",
        "button_hover_background_color": "#DFAFB3",
        "button_text_color": "#6E5F59",
        "card_gap": 32,
        "padding_top": 100,
        "padding_bottom": 88
      },
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "fallback_icon": "pouch",
            "title": "UNA PER IL QUOTIDIANO",
            "description": "Classic è perfetta per gli essenziali di ogni giorno: make-up, skincare e piccoli prodotti sempre a portata di mano.",
            "icon_alt_text": "Pouch quotidiano"
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "fallback_icon": "hairdryer",
            "title": "UNA PER LA ROUTINE COMPLETA",
            "description": "Large è pensata per tutto ciò che richiede più spazio: hair tools, skincare, formati più grandi e trattamenti per ogni esigenza.",
            "icon_alt_text": "Routine completa"
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "fallback_icon": "sparkle",
            "title": "UNA SCELTA PIÙ INTELLIGENTE",
            "description": "Insieme organizzano ogni fase della tua routine, ottimizzando lo spazio e aggiungendo un tocco di bellezza al tuo bagno o alla tua vanity.",
            "icon_alt_text": "Scelta intelligente"
          }
        }
      ]
    }
  ]
}
{% endschema %}
