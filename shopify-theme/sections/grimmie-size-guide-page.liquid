{%- liquid
  assign section_id = section.id

  assign hero_heading = section.settings.hero_heading
  assign hero_text = section.settings.hero_text
  assign hero_image = section.settings.hero_image
  assign hero_image_alt = section.settings.hero_image_alt

  assign choice_title = section.settings.choice_title
  assign visual_title = section.settings.visual_title
  assign fits_title = section.settings.fits_title
  assign table_title = section.settings.table_title
  assign table_col_1 = section.settings.table_col_1
  assign table_col_2 = section.settings.table_col_2
  assign table_col_3 = section.settings.table_col_3
  assign rhythm_title = section.settings.rhythm_title
  assign rhythm_subtitle = section.settings.rhythm_subtitle

  assign bottom_image = section.settings.bottom_image
  assign bottom_image_alt = section.settings.bottom_image_alt
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link

  assign bg_color = section.settings.background_color
  assign secondary_bg = section.settings.secondary_background_color
  assign heading_color = section.settings.heading_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign border_color = section.settings.border_color
  assign card_bg = section.settings.card_background_color
  assign btn_bg = section.settings.button_background_color
  assign btn_text = section.settings.button_text_color
  assign btn_hover_bg = section.settings.button_hover_background_color
-%}

<style>
  .grimmie-size-{{ section_id }} {
    --sg-bg: {{ bg_color }};
    --sg-bg-2: {{ secondary_bg }};
    --sg-heading: {{ heading_color }};
    --sg-text: {{ text_color }};
    --sg-accent: {{ accent_color }};
    --sg-border: {{ border_color }};
    --sg-card-bg: {{ card_bg }};
    --sg-btn-bg: {{ btn_bg }};
    --sg-btn-text: {{ btn_text }};
    --sg-btn-hover-bg: {{ btn_hover_bg }};

    background-color: var(--sg-bg);
    color: var(--sg-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .grimmie-size-{{ section_id }} * { box-sizing: border-box; }

  .grimmie-size-{{ section_id }}__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 56px);
  }

  /* Hero - full-bleed banner with overlaid text (same as FAQ) */
  .grimmie-size-{{ section_id }}__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 5;
    margin-top: -{{ section.settings.padding_top }}px;
    margin-bottom: clamp(48px, 6vw, 80px);
    overflow: hidden;
    background-color: var(--sg-bg-2);
  }

  .grimmie-size-{{ section_id }}__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .grimmie-size-{{ section_id }}__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .grimmie-size-{{ section_id }}__hero-image svg.placeholder {
    width: 100%;
    height: 100%;
    color: var(--sg-accent);
    opacity: 0.4;
  }

  .grimmie-size-{{ section_id }}__hero-content {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(28px, 6vw, 88px) clamp(20px, 5vw, 56px);
    height: 100%;
    display: flex;
    align-items: center;
  }

  .grimmie-size-{{ section_id }}__hero-text {
    max-width: 460px;
    display: flex;
    flex-direction: column;
    gap: clamp(12px, 2vw, 18px);
  }

  .grimmie-size-{{ section_id }}__hero-title {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    color: var(--sg-heading);
    font-size: clamp(24px, 3.2vw, 42px);
    line-height: 1.18;
    margin: 0;
    letter-spacing: -0.005em;
    text-transform: none;
  }

  .grimmie-size-{{ section_id }}__hero-subtitle {
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-weight: 400;
    font-size: clamp(13px, 1vw, 15px);
    line-height: 1.6;
    margin: 0;
    max-width: 380px;
    text-transform: none;
  }

  /* Section headings (lined eyebrow style) */
  .grimmie-size-{{ section_id }}__section-eyebrow {
    text-align: center;
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 clamp(24px, 3vw, 36px);
    font-weight: 600;
    line-height: 1.3;
  }

  .grimmie-size-{{ section_id }}__section-heading {
    text-align: center;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    color: var(--sg-heading);
    font-size: clamp(24px, 3.2vw, 42px);
    line-height: 1.18;
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }

  .grimmie-size-{{ section_id }}__section-sub {
    text-align: center;
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-weight: 400;
    font-size: clamp(13px, 1vw, 15px);
    line-height: 1.6;
    margin: 0 auto clamp(32px, 4vw, 48px);
    max-width: 640px;
  }

  /* Section spacing */
  .grimmie-size-{{ section_id }}__section {
    margin-bottom: clamp(48px, 6vw, 80px);
  }

  /* Choice cards (3 horizontal cards) */
  .grimmie-size-{{ section_id }}__choice-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }

  .grimmie-size-{{ section_id }}__choice-card {
    background-color: var(--sg-card-bg);
    border: 1px solid var(--sg-border);
    border-radius: 6px;
    padding: clamp(20px, 2.4vw, 28px);
    display: flex;
    align-items: center;
    gap: clamp(14px, 1.8vw, 22px);
  }

  .grimmie-size-{{ section_id }}__choice-icon {
    flex-shrink: 0;
    width: clamp(56px, 7vw, 84px);
    height: clamp(56px, 7vw, 84px);
    border-radius: 50%;
    background-color: var(--sg-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sg-heading);
  }

  .grimmie-size-{{ section_id }}__choice-icon svg {
    width: 52%;
    height: 52%;
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .grimmie-size-{{ section_id }}__choice-icon img {
    width: 56%;
    height: 56%;
    object-fit: contain;
  }

  .grimmie-size-{{ section_id }}__choice-body {
    flex: 1;
    min-width: 0;
  }

  .grimmie-size-{{ section_id }}__choice-title {
    font-family: var(--font-body--family);
    color: var(--sg-heading);
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
  }

  .grimmie-size-{{ section_id }}__choice-desc {
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-weight: 400;
    font-size: clamp(13px, 0.95vw, 14.5px);
    line-height: 1.55;
    margin: 0;
  }

  /* Visual size comparison (3 columns w/ dividers) */
  .grimmie-size-{{ section_id }}__visual-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--sg-border);
    border-bottom: 1px solid var(--sg-border);
  }

  .grimmie-size-{{ section_id }}__visual-col {
    padding: clamp(24px, 3vw, 40px) clamp(16px, 2vw, 24px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-right: 1px solid var(--sg-border);
  }

  .grimmie-size-{{ section_id }}__visual-col:last-child {
    border-right: none;
  }

  .grimmie-size-{{ section_id }}__visual-image {
    width: 100%;
    max-width: 260px;
    aspect-ratio: 4 / 3;
    margin-bottom: clamp(16px, 2vw, 24px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grimmie-size-{{ section_id }}__visual-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .grimmie-size-{{ section_id }}__visual-image svg.placeholder {
    width: 70%;
    height: 70%;
    color: var(--sg-accent);
    opacity: 0.5;
  }

  .grimmie-size-{{ section_id }}__visual-title {
    font-family: var(--font-body--family);
    color: var(--sg-heading);
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
  }

  .grimmie-size-{{ section_id }}__visual-size {
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-weight: 400;
    font-size: clamp(13px, 0.95vw, 14.5px);
    line-height: 1.55;
    margin: 0;
  }

  .grimmie-size-{{ section_id }}__visual-link {
    text-decoration: none;
    color: inherit;
    display: contents;
  }

  /* What fits inside (3 photo cards) */
  .grimmie-size-{{ section_id }}__fits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }

  .grimmie-size-{{ section_id }}__fits-card {
    background-color: var(--sg-card-bg);
    border: 1px solid var(--sg-border);
    border-radius: 6px;
    padding: clamp(18px, 2vw, 24px);
    display: flex;
    flex-direction: column;
  }

  .grimmie-size-{{ section_id }}__fits-title {
    font-family: var(--font-body--family);
    color: var(--sg-heading);
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 14px;
    font-weight: 600;
    line-height: 1.3;
    text-align: center;
  }

  .grimmie-size-{{ section_id }}__fits-image {
    width: 100%;
    aspect-ratio: 3 / 2;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 4px;
    background-color: var(--sg-bg-2);
  }

  .grimmie-size-{{ section_id }}__fits-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .grimmie-size-{{ section_id }}__fits-image svg.placeholder {
    width: 60%;
    height: 60%;
    color: var(--sg-accent);
    opacity: 0.45;
  }

  .grimmie-size-{{ section_id }}__fits-desc {
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-weight: 400;
    font-size: clamp(13px, 0.95vw, 14.5px);
    line-height: 1.55;
    margin: 0;
    text-align: center;
  }

  /* Comparison table - premium grid */
  .grimmie-size-{{ section_id }}__table-wrap {
    background-color: var(--sg-card-bg);
    border: 1px solid var(--sg-border);
    border-radius: 18px;
    overflow: hidden;
    max-width: 1100px;
    margin: 0 auto;
  }

  .grimmie-size-{{ section_id }}__table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .grimmie-size-{{ section_id }}__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body--family);
    color: var(--sg-text);
    min-width: 720px;
  }

  /* Product header row */
  .grimmie-size-{{ section_id }}__table thead th {
    padding: clamp(20px, 3vw, 36px) clamp(12px, 2vw, 24px);
    text-align: center;
    vertical-align: middle;
    border-right: 1px solid var(--sg-border);
    border-bottom: 1px solid var(--sg-border);
    background: transparent;
    font-weight: 400;
    font-size: inherit;
    letter-spacing: normal;
    text-transform: none;
    color: var(--sg-text);
  }

  .grimmie-size-{{ section_id }}__table thead th:last-child {
    border-right: none;
  }

  .grimmie-size-{{ section_id }}__table thead th:first-child {
    width: clamp(180px, 22vw, 240px);
    padding: 0;
  }

  .grimmie-size-{{ section_id }}__product {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(10px, 1.4vw, 16px);
  }

  .grimmie-size-{{ section_id }}__product-name {
    font-family: var(--font-body--family);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sg-heading);
    line-height: 1.3;
  }

  .grimmie-size-{{ section_id }}__product-image {
    width: 100%;
    max-width: clamp(120px, 14vw, 180px);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grimmie-size-{{ section_id }}__product-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .grimmie-size-{{ section_id }}__product-image svg.placeholder {
    width: 80%;
    height: 80%;
    color: var(--sg-accent);
    opacity: 0.5;
  }

  .grimmie-size-{{ section_id }}__product-badge {
    display: inline-flex;
    align-items: center;
    background-color: var(--sg-accent);
    color: var(--sg-heading);
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
    white-space: nowrap;
  }

  /* Body rows */
  .grimmie-size-{{ section_id }}__table tbody th,
  .grimmie-size-{{ section_id }}__table tbody td {
    padding: clamp(14px, 1.8vw, 22px) clamp(12px, 2vw, 24px);
    border-bottom: 1px solid var(--sg-border);
    border-right: 1px solid var(--sg-border);
    background: transparent;
    vertical-align: middle;
  }

  .grimmie-size-{{ section_id }}__table tbody tr:last-child th,
  .grimmie-size-{{ section_id }}__table tbody tr:last-child td {
    border-bottom: none;
  }

  .grimmie-size-{{ section_id }}__table tbody td:last-child {
    border-right: none;
  }

  .grimmie-size-{{ section_id }}__table tbody th {
    text-align: left;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sg-heading);
    line-height: 1.3;
  }

  .grimmie-size-{{ section_id }}__row-label {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .grimmie-size-{{ section_id }}__row-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--sg-heading);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grimmie-size-{{ section_id }}__row-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .grimmie-size-{{ section_id }}__row-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .grimmie-size-{{ section_id }}__table tbody td {
    text-align: center;
    font-weight: 400;
    font-size: clamp(13px, 0.95vw, 14.5px);
    line-height: 1.55;
    color: var(--sg-text);
  }

  .grimmie-size-{{ section_id }}__cell-image {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }

  .grimmie-size-{{ section_id }}__cell-image img {
    max-width: 100%;
    max-height: 120px;
    object-fit: contain;
    display: block;
  }

  .grimmie-size-{{ section_id }}__dots {
    display: inline-flex;
    gap: 6px;
    justify-content: center;
    align-items: center;
  }

  .grimmie-size-{{ section_id }}__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }

  .grimmie-size-{{ section_id }}__dot--filled {
    background-color: var(--sg-heading);
  }

  .grimmie-size-{{ section_id }}__dot--empty {
    background-color: transparent;
    border: 1px solid var(--sg-border);
  }

  /* Rhythm cards (4 small cards w/ arrow dividers) */
  .grimmie-size-{{ section_id }}__rhythm-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    gap: clamp(8px, 1.2vw, 16px);
    align-items: stretch;
  }

  .grimmie-size-{{ section_id }}__rhythm-card {
    background-color: var(--sg-card-bg);
    border: 1px solid var(--sg-border);
    border-radius: 6px;
    padding: clamp(18px, 2vw, 24px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
  }

  .grimmie-size-{{ section_id }}__rhythm-icon {
    width: 36px;
    height: 36px;
    color: var(--sg-heading);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2px;
  }

  .grimmie-size-{{ section_id }}__rhythm-icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .grimmie-size-{{ section_id }}__rhythm-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .grimmie-size-{{ section_id }}__rhythm-title {
    font-family: var(--font-body--family);
    color: var(--sg-heading);
    font-size: clamp(11px, 0.85vw, 13px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 600;
    line-height: 1.3;
  }

  .grimmie-size-{{ section_id }}__rhythm-desc {
    font-family: var(--font-body--family);
    color: var(--sg-text);
    font-weight: 400;
    font-size: clamp(13px, 0.95vw, 14.5px);
    line-height: 1.55;
    margin: 0 0 6px;
  }

  .grimmie-size-{{ section_id }}__rhythm-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--sg-accent);
    color: var(--sg-heading);
    font-family: var(--font-body--family);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 0;
    text-decoration: none;
    margin-top: auto;
  }

  .grimmie-size-{{ section_id }}__rhythm-sep {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sg-border);
  }

  .grimmie-size-{{ section_id }}__rhythm-sep svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Bottom image + CTA */
  .grimmie-size-{{ section_id }}__bottom {
    text-align: center;
    margin-top: clamp(40px, 5vw, 64px);
  }

  .grimmie-size-{{ section_id }}__bottom-image {
    position: relative;
    width: 100vw;
    max-width: none;
    margin: 0 calc(50% - 50vw);
    aspect-ratio: 16 / 5;
    overflow: hidden;
  }

  .grimmie-size-{{ section_id }}__bottom-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .grimmie-size-{{ section_id }}__bottom-image svg.placeholder {
    width: 60%;
    height: 60%;
    color: var(--sg-accent);
    opacity: 0.45;
  }

  .grimmie-size-{{ section_id }}__cta {
    position: absolute;
    bottom: clamp(20px, 4vw, 56px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--sg-btn-bg);
    color: var(--sg-btn-text);
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 18px clamp(40px, 6vw, 64px);
    border-radius: 0;
    text-decoration: none;
    border: none;
    cursor: pointer;
    min-height: 52px;
    line-height: 1;
    transition: background-color 200ms ease;
  }

  .grimmie-size-{{ section_id }}__cta:hover,
  .grimmie-size-{{ section_id }}__cta:focus-visible {
    background-color: var(--sg-btn-hover-bg);
  }

  /* Tablet */
  @media (max-width: 900px) {
    .grimmie-size-{{ section_id }}__choice-grid,
    .grimmie-size-{{ section_id }}__fits-grid {
      grid-template-columns: 1fr;
    }

    .grimmie-size-{{ section_id }}__visual-grid {
      grid-template-columns: 1fr;
    }

    .grimmie-size-{{ section_id }}__visual-col {
      border-right: none;
      border-bottom: 1px solid var(--sg-border);
    }

    .grimmie-size-{{ section_id }}__visual-col:last-child {
      border-bottom: none;
    }

    .grimmie-size-{{ section_id }}__rhythm-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .grimmie-size-{{ section_id }}__rhythm-sep {
      display: none;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .grimmie-size-{{ section_id }} {
      padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }

    .grimmie-size-{{ section_id }}__hero {
      aspect-ratio: 12 / 5;
      margin-top: -{{ section.settings.padding_top | times: 0.7 | round }}px;
    }

    .grimmie-size-{{ section_id }}__hero-content {
      padding: 16px 20px;
    }

    .grimmie-size-{{ section_id }}__bottom-image {
      aspect-ratio: 12 / 5;
    }

    .grimmie-size-{{ section_id }}__rhythm-grid {
      grid-template-columns: 1fr;
    }

    .grimmie-size-{{ section_id }}__table-wrap {
      border-radius: 14px;
    }

    .grimmie-size-{{ section_id }}__table-scroll {
      overflow-x: auto;
    }

    .grimmie-size-{{ section_id }}__table tbody th,
    .grimmie-size-{{ section_id }}__table tbody td {
      padding: 12px 10px;
      font-size: 12px;
    }

    .grimmie-size-{{ section_id }}__table thead th {
      padding: 16px 10px;
    }

    .grimmie-size-{{ section_id }}__row-icon {
      width: 18px;
      height: 18px;
    }

    .grimmie-size-{{ section_id }}__row-label {
      gap: 8px;
    }

    .grimmie-size-{{ section_id }}__product-badge {
      font-size: 10px;
      padding: 5px 10px;
      letter-spacing: 0.1em;
    }

    .grimmie-size-{{ section_id }}__cell-image img {
      max-height: 80px;
    }
  }
</style>

<section
  class="grimmie-size-{{ section_id }}"
  aria-label="{{ section.settings.aria_label | default: 'Size guide' | escape }}"
>
  {%- comment -%} HERO {%- endcomment -%}
  <div class="grimmie-size-{{ section_id }}__hero">
    <div class="grimmie-size-{{ section_id }}__hero-image">
      {%- if hero_image != blank -%}
        {{ hero_image | image_url: width: 2400 | image_tag: alt: hero_image_alt, loading: 'eager', widths: '720,960,1200,1600,2000,2400', sizes: '100vw' }}
      {%- else -%}
        <svg class="placeholder" viewBox="0 0 160 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <rect x="0" y="0" width="160" height="60" fill="currentColor" opacity="0.4"/>
        </svg>
      {%- endif -%}
    </div>
    <div class="grimmie-size-{{ section_id }}__hero-content">
      <div class="grimmie-size-{{ section_id }}__hero-text">
        {%- if hero_heading != blank -%}
          <h1 class="grimmie-size-{{ section_id }}__hero-title">{{ hero_heading | newline_to_br }}</h1>
        {%- endif -%}
        {%- if hero_text != blank -%}
          <p class="grimmie-size-{{ section_id }}__hero-subtitle">{{ hero_text | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="grimmie-size-{{ section_id }}__inner">

    {%- comment -%} 1. CHOICE CARDS {%- endcomment -%}
    {%- assign choice_blocks = section.blocks | where: 'type', 'choice_card' -%}
    {%- if choice_title != blank or choice_blocks.size > 0 -%}
      <div class="grimmie-size-{{ section_id }}__section">
        {%- if choice_title != blank -%}
          <p class="grimmie-size-{{ section_id }}__section-eyebrow">{{ choice_title | escape }}</p>
        {%- endif -%}
        {%- if choice_blocks.size > 0 -%}
          <div class="grimmie-size-{{ section_id }}__choice-grid">
            {%- for block in choice_blocks -%}
              <div class="grimmie-size-{{ section_id }}__choice-card" {{ block.shopify_attributes }}>
                <div class="grimmie-size-{{ section_id }}__choice-icon" aria-hidden="{% if block.settings.icon_alt == blank %}true{% else %}false{% endif %}">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 120 | image_tag: alt: block.settings.icon_alt, loading: 'lazy' }}
                  {%- else -%}
                    {%- case block.settings.fallback_icon -%}
                      {%- when 'classic' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt | default: 'Classic' | escape }}">
                          <rect x="5" y="12" width="22" height="12" rx="2"/>
                          <path d="M10 12 V10 a3 3 0 0 1 3 -3 h6 a3 3 0 0 1 3 3 V12"/>
                        </svg>
                      {%- when 'large' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt | default: 'Large' | escape }}">
                          <rect x="3" y="10" width="26" height="16" rx="2.5"/>
                          <path d="M9 10 V8 a3 3 0 0 1 3 -3 h8 a3 3 0 0 1 3 3 V10"/>
                        </svg>
                      {%- when 'duo' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt | default: 'Duo' | escape }}">
                          <rect x="2" y="12" width="14" height="12" rx="2"/>
                          <rect x="17" y="14" width="13" height="10" rx="2"/>
                          <path d="M5 12 V10 a2.5 2.5 0 0 1 2.5 -2.5 h3 a2.5 2.5 0 0 1 2.5 2.5 V12"/>
                        </svg>
                      {%- else -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.icon_alt | default: 'Icon' | escape }}"><circle cx="16" cy="16" r="8"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
                <div class="grimmie-size-{{ section_id }}__choice-body">
                  {%- if block.settings.title != blank -%}
                    <h3 class="grimmie-size-{{ section_id }}__choice-title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="grimmie-size-{{ section_id }}__choice-desc">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} 2. VISUAL SIZE COMPARISON {%- endcomment -%}
    {%- assign visual_blocks = section.blocks | where: 'type', 'size_visual' -%}
    {%- if visual_title != blank or visual_blocks.size > 0 -%}
      <div class="grimmie-size-{{ section_id }}__section">
        {%- if visual_title != blank -%}
          <p class="grimmie-size-{{ section_id }}__section-eyebrow">{{ visual_title | escape }}</p>
        {%- endif -%}
        {%- if visual_blocks.size > 0 -%}
          <div class="grimmie-size-{{ section_id }}__visual-grid">
            {%- for block in visual_blocks -%}
              {%- assign visual_link = block.settings.link -%}
              {%- capture visual_inner -%}
                <div class="grimmie-size-{{ section_id }}__visual-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 520 | image_tag: alt: block.settings.image_alt, loading: 'lazy', widths: '260,360,520', sizes: '(max-width: 900px) 80vw, 320px' }}
                  {%- else -%}
                    <svg class="placeholder" viewBox="0 0 160 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                      <rect x="30" y="45" width="100" height="55" rx="8" fill="currentColor" opacity="0.5"/>
                      <rect x="55" y="30" width="50" height="22" rx="6" fill="none" stroke="currentColor" stroke-width="2.5"/>
                    </svg>
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="grimmie-size-{{ section_id }}__visual-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.size_text != blank -%}
                  <p class="grimmie-size-{{ section_id }}__visual-size">{{ block.settings.size_text | escape }}</p>
                {%- endif -%}
              {%- endcapture -%}
              <div class="grimmie-size-{{ section_id }}__visual-col" {{ block.shopify_attributes }}>
                {%- if visual_link != blank -%}
                  <a class="grimmie-size-{{ section_id }}__visual-link" href="{{ visual_link }}">{{ visual_inner }}</a>
                {%- else -%}
                  {{ visual_inner }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} 3. WHAT FITS INSIDE {%- endcomment -%}
    {%- assign fits_blocks = section.blocks | where: 'type', 'fits_card' -%}
    {%- if fits_title != blank or fits_blocks.size > 0 -%}
      <div class="grimmie-size-{{ section_id }}__section">
        {%- if fits_title != blank -%}
          <p class="grimmie-size-{{ section_id }}__section-eyebrow">{{ fits_title | escape }}</p>
        {%- endif -%}
        {%- if fits_blocks.size > 0 -%}
          <div class="grimmie-size-{{ section_id }}__fits-grid">
            {%- for block in fits_blocks -%}
              <div class="grimmie-size-{{ section_id }}__fits-card" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h3 class="grimmie-size-{{ section_id }}__fits-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                <div class="grimmie-size-{{ section_id }}__fits-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 720 | image_tag: alt: block.settings.image_alt, loading: 'lazy', widths: '360,540,720', sizes: '(max-width: 900px) 90vw, 380px' }}
                  {%- else -%}
                    <svg class="placeholder" viewBox="0 0 200 130" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                      <rect x="40" y="55" width="120" height="60" rx="8" fill="currentColor" opacity="0.5"/>
                      <circle cx="70" cy="40" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
                      <rect x="100" y="32" width="20" height="20" rx="3" fill="none" stroke="currentColor" stroke-width="2"/>
                    </svg>
                  {%- endif -%}
                </div>
                {%- if block.settings.description != blank -%}
                  <p class="grimmie-size-{{ section_id }}__fits-desc">{{ block.settings.description | escape }}</p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} 4. COMPARISON TABLE - premium grid {%- endcomment -%}
    {%- assign table_blocks = section.blocks | where: 'type', 'table_row' -%}
    {%- if table_title != blank or table_blocks.size > 0 -%}
      <div class="grimmie-size-{{ section_id }}__section">
        {%- if table_title != blank -%}
          <p class="grimmie-size-{{ section_id }}__section-eyebrow">{{ table_title | escape }}</p>
        {%- endif -%}
        {%- if table_blocks.size > 0 -%}
          <div class="grimmie-size-{{ section_id }}__table-wrap">
            <div class="grimmie-size-{{ section_id }}__table-scroll">
              <table class="grimmie-size-{{ section_id }}__table">
                <thead>
                  <tr>
                    <th scope="col" aria-label="Caratteristiche"></th>
                    {%- for col_index in (1..3) -%}
                      {%- case col_index -%}
                        {%- when 1 -%}
                          {%- assign p_name = table_col_1 -%}
                          {%- assign p_image = section.settings.classic_image -%}
                          {%- assign p_badge = section.settings.classic_badge -%}
                        {%- when 2 -%}
                          {%- assign p_name = table_col_2 -%}
                          {%- assign p_image = section.settings.large_image -%}
                          {%- assign p_badge = section.settings.large_badge -%}
                        {%- when 3 -%}
                          {%- assign p_name = table_col_3 -%}
                          {%- assign p_image = section.settings.duo_image -%}
                          {%- assign p_badge = section.settings.duo_badge -%}
                      {%- endcase -%}
                      <th scope="col">
                        <div class="grimmie-size-{{ section_id }}__product">
                          {%- if p_name != blank -%}
                            <span class="grimmie-size-{{ section_id }}__product-name">{{ p_name | escape }}</span>
                          {%- endif -%}
                          <div class="grimmie-size-{{ section_id }}__product-image">
                            {%- if p_image != blank -%}
                              {{ p_image | image_url: width: 400 | image_tag: alt: p_name, loading: 'lazy', widths: '160,240,360,400' }}
                            {%- else -%}
                              <svg class="placeholder" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <rect x="20" y="42" width="60" height="38" rx="6" fill="currentColor" opacity="0.5"/>
                                <rect x="35" y="28" width="30" height="18" rx="4" fill="none" stroke="currentColor" stroke-width="2"/>
                              </svg>
                            {%- endif -%}
                          </div>
                          {%- if p_badge != blank -%}
                            <span class="grimmie-size-{{ section_id }}__product-badge">{{ p_badge | escape }}</span>
                          {%- endif -%}
                        </div>
                      </th>
                    {%- endfor -%}
                  </tr>
                </thead>
                <tbody>
                  {%- for block in table_blocks -%}
                    <tr {{ block.shopify_attributes }}>
                      <th scope="row">
                        <div class="grimmie-size-{{ section_id }}__row-label">
                          <span class="grimmie-size-{{ section_id }}__row-icon" aria-hidden="true">
                            {%- if block.settings.icon != blank -%}
                              {{ block.settings.icon | image_url: width: 60 | image_tag: alt: '', loading: 'lazy' }}
                            {%- else -%}
                              {%- case block.settings.fallback_icon -%}
                                {%- when 'ruler' -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 16 L21 16 M3 16 L3 9 M21 16 L21 9 M6 16 V13 M9 16 V12 M12 16 V11 M15 16 V12 M18 16 V13"/></svg>
                                {%- when 'target' -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/></svg>
                                {%- when 'lipstick' -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="8" y="13" width="8" height="8" rx="1"/><path d="M9 13 V9 L11 6 L13 6 L15 9 V13"/></svg>
                                {%- when 'hairdryer' -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 10 a4 4 0 0 1 4 -4 h9 a3 3 0 0 1 3 3 v4 a3 3 0 0 1 -3 3 h-7 v3 l-2 3 h-2 l2 -3 v-3 a4 4 0 0 1 -4 -4 z"/></svg>
                                {%- when 'suitcase' -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="8" width="18" height="13" rx="1.5"/><path d="M9 8 V5 a1 1 0 0 1 1 -1 h4 a1 1 0 0 1 1 1 V8"/><path d="M9 12 V18 M15 12 V18"/></svg>
                                {%- when 'eye' -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M2 12 C 5 6 9 5 12 5 C 15 5 19 6 22 12 C 19 18 15 19 12 19 C 9 19 5 18 2 12 Z"/><circle cx="12" cy="12" r="3"/></svg>
                                {%- else -%}
                                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="6"/></svg>
                              {%- endcase -%}
                            {%- endif -%}
                          </span>
                          <span>{{ block.settings.row_label | escape }}</span>
                        </div>
                      </th>
                      {%- if block.settings.value_type == 'dots' -%}
                        {%- assign dots_total = 5 -%}
                        {%- for prod_index in (1..3) -%}
                          {%- case prod_index -%}
                            {%- when 1 -%}{%- assign level = block.settings.classic_level -%}
                            {%- when 2 -%}{%- assign level = block.settings.large_level -%}
                            {%- when 3 -%}{%- assign level = block.settings.duo_level -%}
                          {%- endcase -%}
                          <td>
                            <span class="grimmie-size-{{ section_id }}__dots" aria-label="{{ level }} su {{ dots_total }}">
                              {%- for i in (1..dots_total) -%}
                                {%- if i <= level -%}
                                  <span class="grimmie-size-{{ section_id }}__dot grimmie-size-{{ section_id }}__dot--filled" aria-hidden="true"></span>
                                {%- else -%}
                                  <span class="grimmie-size-{{ section_id }}__dot grimmie-size-{{ section_id }}__dot--empty" aria-hidden="true"></span>
                                {%- endif -%}
                              {%- endfor -%}
                            </span>
                          </td>
                        {%- endfor -%}
                      {%- else -%}
                        <td>
                          {%- if block.settings.classic_cell_image != blank -%}
                            <div class="grimmie-size-{{ section_id }}__cell-image">
                              {{ block.settings.classic_cell_image | image_url: width: 400 | image_tag: alt: block.settings.classic_cell_image_alt, loading: 'lazy', widths: '160,240,360,400' }}
                            </div>
                          {%- endif -%}
                          {{ block.settings.classic_text | escape }}
                        </td>
                        <td>
                          {%- if block.settings.large_cell_image != blank -%}
                            <div class="grimmie-size-{{ section_id }}__cell-image">
                              {{ block.settings.large_cell_image | image_url: width: 400 | image_tag: alt: block.settings.large_cell_image_alt, loading: 'lazy', widths: '160,240,360,400' }}
                            </div>
                          {%- endif -%}
                          {{ block.settings.large_text | escape }}
                        </td>
                        <td>
                          {%- if block.settings.duo_cell_image != blank -%}
                            <div class="grimmie-size-{{ section_id }}__cell-image">
                              {{ block.settings.duo_cell_image | image_url: width: 400 | image_tag: alt: block.settings.duo_cell_image_alt, loading: 'lazy', widths: '160,240,360,400' }}
                            </div>
                          {%- endif -%}
                          {{ block.settings.duo_text | escape }}
                        </td>
                      {%- endif -%}
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} 5. RHYTHM CARDS {%- endcomment -%}
    {%- assign rhythm_blocks = section.blocks | where: 'type', 'rhythm_card' -%}
    {%- if rhythm_title != blank or rhythm_blocks.size > 0 -%}
      <div class="grimmie-size-{{ section_id }}__section">
        {%- if rhythm_title != blank -%}
          <h2 class="grimmie-size-{{ section_id }}__section-heading">{{ rhythm_title | escape }}</h2>
        {%- endif -%}
        {%- if rhythm_subtitle != blank -%}
          <p class="grimmie-size-{{ section_id }}__section-sub">{{ rhythm_subtitle | escape }}</p>
        {%- endif -%}
        {%- if rhythm_blocks.size > 0 -%}
          <div class="grimmie-size-{{ section_id }}__rhythm-grid">
            {%- for block in rhythm_blocks -%}
              <div class="grimmie-size-{{ section_id }}__rhythm-card" {{ block.shopify_attributes }}>
                <div class="grimmie-size-{{ section_id }}__rhythm-icon" aria-hidden="true">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 80 | image_tag: alt: '', loading: 'lazy' }}
                  {%- else -%}
                    {%- case block.settings.fallback_icon -%}
                      {%- when 'sun' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <circle cx="16" cy="16" r="5.5"/>
                          <path d="M16 3 V6.5 M16 25.5 V29 M3 16 H6.5 M25.5 16 H29 M6.5 6.5 L9 9 M23 23 L25.5 25.5 M25.5 6.5 L23 9 M9 23 L6.5 25.5"/>
                        </svg>
                      {%- when 'mirror' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <circle cx="16" cy="12" r="7"/>
                          <path d="M16 19 V26"/>
                          <path d="M11 28 H21"/>
                        </svg>
                      {%- when 'brush' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <ellipse cx="13" cy="13" rx="8" ry="6" transform="rotate(-30 13 13)"/>
                          <path d="M18.5 16.5 L26 24"/>
                          <path d="M9 9 L11 11 M12 7 L14 9 M15 8 L17 10"/>
                        </svg>
                      {%- when 'plane' -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M3 17 L29 9 L24 16 L13 18 L9 26 L7 19 Z"/>
                        </svg>
                      {%- else -%}
                        <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="16" cy="16" r="8"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="grimmie-size-{{ section_id }}__rhythm-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="grimmie-size-{{ section_id }}__rhythm-desc">{{ block.settings.description | escape }}</p>
                {%- endif -%}
                {%- if block.settings.tag_text != blank -%}
                  {%- if block.settings.tag_link != blank -%}
                    <a class="grimmie-size-{{ section_id }}__rhythm-tag" href="{{ block.settings.tag_link }}">{{ block.settings.tag_text | escape }}</a>
                  {%- else -%}
                    <span class="grimmie-size-{{ section_id }}__rhythm-tag">{{ block.settings.tag_text | escape }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>
              {%- unless forloop.last -%}
                <div class="grimmie-size-{{ section_id }}__rhythm-sep" aria-hidden="true">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 12 H19 M14 7 L19 12 L14 17"/></svg>
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} 6. BOTTOM IMAGE WITH OVERLAID CTA {%- endcomment -%}
    {%- if bottom_image != blank or cta_text != blank -%}
      <div class="grimmie-size-{{ section_id }}__bottom">
        <div class="grimmie-size-{{ section_id }}__bottom-image">
          {%- if bottom_image != blank -%}
            {{ bottom_image | image_url: width: 2400 | image_tag: alt: bottom_image_alt, loading: 'lazy', widths: '720,960,1200,1600,2000,2400', sizes: '100vw' }}
          {%- else -%}
            <svg class="placeholder" viewBox="0 0 320 100" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <rect x="0" y="0" width="320" height="100" fill="currentColor" opacity="0.4"/>
            </svg>
          {%- endif -%}
          {%- if cta_text != blank -%}
            {%- if cta_link != blank -%}
              <a class="grimmie-size-{{ section_id }}__cta" href="{{ cta_link }}">{{ cta_text | escape }}</a>
            {%- else -%}
              <span class="grimmie-size-{{ section_id }}__cta" role="button">{{ cta_text | escape }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

