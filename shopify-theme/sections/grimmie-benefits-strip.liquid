{%- liquid
  assign section_id = section.id
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign divider_color = section.settings.divider_color
  assign arrow_bg_color = section.settings.arrow_background_color
  assign arrow_icon_color = section.settings.arrow_icon_color
  assign dot_active_color = section.settings.dot_active_color
  assign dot_inactive_color = section.settings.dot_inactive_color
  assign show_dividers = section.settings.show_dividers
  assign desktop_columns = section.settings.desktop_columns
  assign mobile_columns = section.settings.mobile_columns
  assign tablet_columns = section.settings.tablet_columns
  assign title_letter_spacing = section.settings.title_letter_spacing
  assign font_stack = "'Avenir Next', 'Avenir', 'Nunito Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif"
-%}

<style>
  .grimmie-benefits-{{ section_id }} {
    --gbs-bg: {{ bg_color }};
    --gbs-text: {{ text_color }};
    --gbs-accent: {{ accent_color }};
    --gbs-divider: {{ divider_color }};
    --gbs-arrow-bg: {{ arrow_bg_color }};
    --gbs-arrow-icon: {{ arrow_icon_color }};
    --gbs-dot-active: {{ dot_active_color }};
    --gbs-dot-inactive: {{ dot_inactive_color }};
    --gbs-desktop-cols: {{ desktop_columns }};
    --gbs-tablet-cols: {{ tablet_columns }};
    --gbs-mobile-cols: {{ mobile_columns }};
    --gbs-title-tracking: {{ title_letter_spacing }}em;
    --gbs-font: {{ font_stack }};

    position: relative;
    background-color: var(--gbs-bg);
    color: var(--gbs-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .grimmie-benefits-{{ section_id }} * {
    box-sizing: border-box;
  }

  .grimmie-benefits-{{ section_id }}__inner {
    max-width: 1600px;
    margin: 0 auto;
    padding-left: clamp(16px, 4vw, 64px);
    padding-right: clamp(16px, 4vw, 64px);
    position: relative;
  }

  .grimmie-benefits-{{ section_id }}__grid {
    display: grid;
    grid-template-columns: repeat(var(--gbs-desktop-cols), minmax(0, 1fr));
    align-items: stretch;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .grimmie-benefits-{{ section_id }}__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    padding: 8px clamp(12px, 2vw, 28px);
    position: relative;
    list-style: none;
  }

  .grimmie-benefits-{{ section_id }}__item + .grimmie-benefits-{{ section_id }}__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 12%;
    bottom: 12%;
    width: 1px;
    background-color: var(--gbs-divider);
    display: {% if show_dividers %}block{% else %}none{% endif %};
  }

  .grimmie-benefits-{{ section_id }}__icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    color: var(--gbs-text);
  }

  .grimmie-benefits-{{ section_id }}__icon img,
  .grimmie-benefits-{{ section_id }}__icon svg {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
  }

  .grimmie-benefits-{{ section_id }}__icon svg {
    stroke: var(--gbs-text);
    fill: none;
  }

  .grimmie-benefits-{{ section_id }}__icon .gbs-accent {
    fill: var(--gbs-accent);
    stroke: none;
  }

  .grimmie-benefits-{{ section_id }}__title {
    font-family: var(--gbs-font);
    font-size: clamp(11px, 0.78vw, 13px);
    font-weight: 500;
    letter-spacing: var(--gbs-title-tracking);
    text-transform: uppercase;
    color: var(--gbs-text);
    margin: 0 0 14px 0;
    line-height: 1.3;
  }

  .grimmie-benefits-{{ section_id }}__description {
    font-family: var(--gbs-font);
    font-size: clamp(12px, 0.85vw, 14px);
    font-weight: 400;
    color: var(--gbs-text);
    margin: 0;
    line-height: 1.65;
    max-width: 22ch;
    opacity: 0.92;
  }

  /* Carousel navigation arrows (only shown on tablet & mobile) */
  .grimmie-benefits-{{ section_id }}__nav {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--gbs-arrow-bg);
    border: none;
    color: var(--gbs-arrow-icon);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    padding: 0;
    box-shadow: 0 2px 10px rgba(110, 95, 89, 0.12);
    transition: filter 0.2s ease, opacity 0.2s ease, transform 0.15s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .grimmie-benefits-{{ section_id }}__nav:hover {
    filter: brightness(0.94);
    transform: translateY(-50%) scale(1.06);
  }

  .grimmie-benefits-{{ section_id }}__nav:focus-visible {
    outline: 2px solid var(--gbs-text);
    outline-offset: 2px;
  }

  .grimmie-benefits-{{ section_id }}__nav[disabled] {
    opacity: 0;
    pointer-events: none;
  }

  .grimmie-benefits-{{ section_id }}__nav svg {
    width: 14px;
    height: 14px;
    stroke: var(--gbs-arrow-icon);
    stroke-width: 1.8;
    fill: none;
  }

  .grimmie-benefits-{{ section_id }}__nav--prev {
    left: 8px;
  }

  .grimmie-benefits-{{ section_id }}__nav--next {
    right: 8px;
  }

  /* Pagination dots (only shown on tablet & mobile) */
  .grimmie-benefits-{{ section_id }}__dots {
    display: none;
    justify-content: center;
    align-items: center;
    gap: 10px;
    padding-top: 24px;
    padding-bottom: 0;
    margin: 0;
    list-style: none;
  }

  .grimmie-benefits-{{ section_id }}__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--gbs-dot-inactive);
    border: none;
    padding: 0;
    cursor: pointer;
    opacity: 0.55;
    transition: background-color 0.25s ease, opacity 0.25s ease, transform 0.25s ease, width 0.25s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .grimmie-benefits-{{ section_id }}__dot:hover {
    opacity: 0.85;
  }

  .grimmie-benefits-{{ section_id }}__dot[aria-current="true"] {
    background-color: var(--gbs-dot-active);
    opacity: 1;
    transform: scale(1.35);
  }

  .grimmie-benefits-{{ section_id }}__dot:focus-visible {
    outline: 2px solid var(--gbs-text);
    outline-offset: 3px;
  }

  /* Tablet — switch to horizontal scroll carousel */
  @media (max-width: 1024px) {
    .grimmie-benefits-{{ section_id }}__inner {
      padding-left: clamp(48px, 6vw, 64px);
      padding-right: clamp(48px, 6vw, 64px);
    }

    .grimmie-benefits-{{ section_id }}__grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .grimmie-benefits-{{ section_id }}__grid::-webkit-scrollbar {
      display: none;
    }

    .grimmie-benefits-{{ section_id }}__item {
      flex: 0 0 calc(100% / var(--gbs-tablet-cols));
      scroll-snap-align: start;
      padding-top: 16px;
      padding-bottom: 16px;
    }

    .grimmie-benefits-{{ section_id }}__item + .grimmie-benefits-{{ section_id }}__item::before {
      display: none !important;
    }

    {% if show_dividers %}
      .grimmie-benefits-{{ section_id }}__item + .grimmie-benefits-{{ section_id }}__item {
        border-left: 1px solid var(--gbs-divider);
      }
    {% endif %}

    .grimmie-benefits-{{ section_id }}__nav {
      display: flex;
    }

    .grimmie-benefits-{{ section_id }}__dots {
      display: flex;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .grimmie-benefits-{{ section_id }} {
      padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }

    .grimmie-benefits-{{ section_id }}__inner {
      padding-left: clamp(40px, 10vw, 56px);
      padding-right: clamp(40px, 10vw, 56px);
    }

    .grimmie-benefits-{{ section_id }}__item {
      flex: 0 0 calc(100% / var(--gbs-mobile-cols));
      padding: 16px 12px;
    }

    .grimmie-benefits-{{ section_id }}__icon {
      width: 44px;
      height: 44px;
      margin-bottom: 16px;
    }

    .grimmie-benefits-{{ section_id }}__title {
      font-size: 11px;
      margin-bottom: 10px;
    }

    .grimmie-benefits-{{ section_id }}__description {
      font-size: 12.5px;
      max-width: 24ch;
    }

    .grimmie-benefits-{{ section_id }}__nav {
      width: 34px;
      height: 34px;
      left: 4px;
    }

    .grimmie-benefits-{{ section_id }}__nav--next {
      left: auto;
      right: 4px;
    }

    .grimmie-benefits-{{ section_id }}__dots {
      padding-top: 18px;
      gap: 8px;
    }

    .grimmie-benefits-{{ section_id }}__dot {
      width: 6px;
      height: 6px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .grimmie-benefits-{{ section_id }}__grid {
      scroll-behavior: auto;
    }
  }
</style>

<section
  class="grimmie-benefits grimmie-benefits-{{ section_id }}"
  aria-label="{{ section.settings.aria_label | default: 'Benefits' | escape }}"
  aria-roledescription="carousel"
  data-gbs-root="{{ section_id }}"
  {{ section.shopify_attributes }}
>
  <button
    type="button"
    class="grimmie-benefits-{{ section_id }}__nav grimmie-benefits-{{ section_id }}__nav--prev"
    aria-label="{{ section.settings.prev_label | default: 'Previous' | escape }}"
    data-gbs-direction="prev"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M15 18 L9 12 L15 6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="grimmie-benefits-{{ section_id }}__inner">
    <ul
      class="grimmie-benefits-{{ section_id }}__grid"
      role="list"
      data-gbs-track="{{ section_id }}"
    >
      {%- for block in section.blocks -%}
        <li class="grimmie-benefits-{{ section_id }}__item" {{ block.shopify_attributes }}>
          <div class="grimmie-benefits-{{ section_id }}__icon" aria-hidden="{% if block.settings.alt_text == blank %}true{% else %}false{% endif %}">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 160 | image_tag: alt: block.settings.alt_text, loading: 'lazy', widths: '56,112,160', class: 'gbs-icon-img' }}
            {%- else -%}
              {%- case block.settings.fallback_icon -%}
                {%- when 'bag' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Structured bag' | escape }}">
                    <rect x="10" y="22" width="44" height="28" rx="3" stroke-width="1.6"/>
                    <path d="M22 22 V18 a10 10 0 0 1 20 0 V22" stroke-width="1.6" stroke-linecap="round"/>
                    <path d="M16 30 H30" stroke-width="1.4" stroke-linecap="round"/>
                    <path d="M54 16 l2 -2 M58 14 l-1.5 1.5 M55 13 l1 2" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                {%- when 'droplet' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Droplet' | escape }}">
                    <path d="M32 8 C 20 24 16 34 16 42 a16 16 0 0 0 32 0 C 48 34 44 24 32 8 Z" stroke-width="1.6" stroke-linejoin="round"/>
                    <ellipse class="gbs-accent" cx="44" cy="44" rx="6" ry="8"/>
                  </svg>
                {%- when 'feather' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Feather' | escape }}">
                    <path d="M44 14 C 22 18 14 32 16 50 C 34 52 48 44 52 22 C 52 16 50 14 44 14 Z" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M48 18 L 20 46" stroke-width="1.4" stroke-linecap="round"/>
                    <path d="M28 42 H 40 M32 36 H 42 M36 30 H 44" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                {%- when 'pouch' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Organizer pouch' | escape }}">
                    <rect x="8" y="20" width="48" height="26" rx="4" stroke-width="1.6"/>
                    <rect class="gbs-accent" x="14" y="30" width="20" height="8" rx="1"/>
                    <path d="M40 26 L48 26" stroke-width="1.4" stroke-linecap="round"/>
                    <circle cx="50" cy="26" r="1.4" fill="currentColor" stroke="none"/>
                  </svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Shield' | escape }}">
                    <path d="M32 8 L 52 16 V32 C 52 44 42 52 32 56 C 22 52 12 44 12 32 V16 Z" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M24 32 L 30 38 L 42 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="stroke: var(--gbs-accent);"/>
                  </svg>
                {%- when 'airplane' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Airplane' | escape }}">
                    <path d="M8 36 L 56 18 L 50 30 L 28 36 L 22 50 L 18 50 L 20 38 L 8 38 Z" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M54 12 l2 -2 M58 10 l-1.5 1.5 M55 9 l1 2" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Heart' | escape }}">
                    <path d="M32 52 C 18 42 10 34 10 24 a10 10 0 0 1 22 -4 a10 10 0 0 1 22 4 C 54 34 46 42 32 52 Z" stroke-width="1.6" stroke-linejoin="round"/>
                  </svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Star' | escape }}">
                    <path d="M32 8 L 39 24 L 56 26 L 43 38 L 47 56 L 32 47 L 17 56 L 21 38 L 8 26 L 25 24 Z" stroke-width="1.6" stroke-linejoin="round"/>
                  </svg>
                {%- when 'leaf' -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Leaf' | escape }}">
                    <path d="M48 12 C 24 14 12 28 12 50 C 34 50 50 36 52 16 C 52 14 50 12 48 12 Z" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M48 16 L 18 46" stroke-width="1.4" stroke-linecap="round"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="{{ block.settings.alt_text | default: 'Benefit' | escape }}">
                    <circle cx="32" cy="32" r="20" stroke-width="1.6"/>
                  </svg>
              {%- endcase -%}
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="grimmie-benefits-{{ section_id }}__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="grimmie-benefits-{{ section_id }}__description">{{ block.settings.description | escape | newline_to_br }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div
      class="grimmie-benefits-{{ section_id }}__dots"
      data-gbs-dots
      role="tablist"
      aria-label="{{ section.settings.dots_label | default: 'Carousel pagination' | escape }}"
    ></div>
  </div>

  <button
    type="button"
    class="grimmie-benefits-{{ section_id }}__nav grimmie-benefits-{{ section_id }}__nav--next"
    aria-label="{{ section.settings.next_label | default: 'Next' | escape }}"
    data-gbs-direction="next"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M9 6 L15 12 L9 18" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</section>

<script>
  (function () {
    var sectionId = {{ section_id | json }};
    var root = document.querySelector('[data-gbs-root="' + sectionId + '"]');
    if (!root) return;
    var track = root.querySelector('[data-gbs-track="' + sectionId + '"]');
    var prevBtn = root.querySelector('.grimmie-benefits-' + sectionId + '__nav--prev');
    var nextBtn = root.querySelector('.grimmie-benefits-' + sectionId + '__nav--next');
    var dots = root.querySelector('[data-gbs-dots]');
    if (!track || !prevBtn || !nextBtn) return;

    function itemWidth() {
      var first = track.firstElementChild;
      return first ? first.getBoundingClientRect().width : 0;
    }

    function itemsPerView() {
      var w = itemWidth();
      if (!w) return 1;
      return Math.max(1, Math.round(track.clientWidth / w));
    }

    function pageCount() {
      return Math.max(1, track.children.length);
    }

    function currentPage() {
      var w = itemWidth();
      if (!w) return 0;
      var idx = Math.round(track.scrollLeft / w);
      var max = pageCount() - 1;
      if (idx < 0) idx = 0;
      if (idx > max) idx = max;
      return idx;
    }

    function scrollToPage(idx) {
      var w = itemWidth();
      if (!w) return;
      track.scrollTo({ left: idx * w, behavior: 'smooth' });
    }

    function renderDots() {
      if (!dots) return;
      var count = pageCount();
      if (count <= 1) {
        dots.style.display = 'none';
        dots.innerHTML = '';
        return;
      }
      dots.style.removeProperty('display');
      if (dots.children.length !== count) {
        dots.innerHTML = '';
        for (var i = 0; i < count; i++) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'grimmie-benefits-' + sectionId + '__dot';
          btn.setAttribute('role', 'tab');
          btn.setAttribute('aria-label', 'Page ' + (i + 1));
          btn.dataset.gbsPage = String(i);
          btn.addEventListener('click', function () {
            scrollToPage(parseInt(this.dataset.gbsPage, 10));
          });
          dots.appendChild(btn);
        }
      }
      updateActiveDot();
    }

    function updateActiveDot() {
      if (!dots) return;
      var cur = currentPage();
      var children = dots.children;
      for (var i = 0; i < children.length; i++) {
        if (i === cur) {
          children[i].setAttribute('aria-current', 'true');
          children[i].setAttribute('aria-selected', 'true');
        } else {
          children[i].removeAttribute('aria-current');
          children[i].setAttribute('aria-selected', 'false');
        }
      }
    }

    function update() {
      var max = track.scrollWidth - track.clientWidth;
      var atStart = track.scrollLeft <= 1;
      var atEnd = track.scrollLeft >= max - 1;
      if (atStart) { prevBtn.setAttribute('disabled', ''); } else { prevBtn.removeAttribute('disabled'); }
      if (atEnd) { nextBtn.setAttribute('disabled', ''); } else { nextBtn.removeAttribute('disabled'); }
      updateActiveDot();
    }

    function go(direction) {
      var w = itemWidth();
      if (!w) return;
      track.scrollBy({ left: direction * w, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', function () { go(-1); });
    nextBtn.addEventListener('click', function () { go(1); });
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', function () {
      renderDots();
      update();
    });
    renderDots();
    update();
  })();
</script>

{% schema %}
{
  "name": "Grimmie Benefits Strip",
  "tag": "section",
  "class": "grimmie-benefits-strip-section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F7F1EE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & icon color",
      "default": "#6E5F59"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (blush) color",
      "default": "#EACBC8"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#DDD2CA"
    },
    {
      "type": "color",
      "id": "arrow_background_color",
      "label": "Arrow background color (carousel)",
      "default": "#EACBC8"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Arrow icon color (carousel)",
      "default": "#F1EBE6"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color (carousel)",
      "default": "#EACBC8"
    },
    {
      "type": "color",
      "id": "dot_inactive_color",
      "label": "Inactive dots color (carousel)",
      "default": "#6E5F59"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "paragraph",
      "content": "On desktop the items are shown in a grid. On tablet and mobile they become a horizontal carousel with arrows on the sides of the screen."
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "tablet_columns",
      "label": "Items visible per view — tablet (carousel)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Items visible per view — mobile (carousel)",
      "options": [
        { "value": "1", "label": "1 item" },
        { "value": "2", "label": "2 items" },
        { "value": "3", "label": "3 items" }
      ],
      "default": "3"
    },
