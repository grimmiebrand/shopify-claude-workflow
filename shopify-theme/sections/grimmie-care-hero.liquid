{%- liquid
  assign section_id = section.id
  assign eyebrow = section.settings.eyebrow
  assign hero_heading = section.settings.hero_heading
  assign hero_text = section.settings.hero_text
  assign hero_image = section.settings.hero_image
  assign hero_image_alt = section.settings.hero_image_alt

  assign bg_color = section.settings.background_color
  assign secondary_bg = section.settings.secondary_background_color
  assign heading_color = section.settings.heading_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
-%}

<style>
  .grimmie-care-hero-{{ section_id }} {
    --gch-bg: {{ bg_color }};
    --gch-bg-2: {{ secondary_bg }};
    --gch-heading: {{ heading_color }};
    --gch-text: {{ text_color }};
    --gch-accent: {{ accent_color }};

    background-color: var(--gch-bg);
    color: var(--gch-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .grimmie-care-hero-{{ section_id }} * { box-sizing: border-box; }

  .grimmie-care-hero-{{ section_id }}__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 5;
    margin-top: -{{ section.settings.padding_top }}px;
    overflow: hidden;
    background-color: var(--gch-bg-2);
  }

  .grimmie-care-hero-{{ section_id }}__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .grimmie-care-hero-{{ section_id }}__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .grimmie-care-hero-{{ section_id }}__hero-image svg.placeholder {
    width: 100%;
    height: 100%;
    color: var(--gch-accent);
    opacity: 0.4;
  }

  .grimmie-care-hero-{{ section_id }}__hero-content {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(28px, 6vw, 88px) clamp(20px, 5vw, 56px);
    height: 100%;
    display: flex;
    align-items: center;
  }

  .grimmie-care-hero-{{ section_id }}__hero-text {
    max-width: 460px;
    display: flex;
    flex-direction: column;
    gap: clamp(12px, 2vw, 18px);
  }

  .grimmie-care-hero-{{ section_id }}__eyebrow {
    font-family: var(--font-body--family);
    font-size: clamp(11px, 0.85vw, 13px);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gch-accent);
    margin: 0;
    line-height: 1.3;
  }

  .grimmie-care-hero-{{ section_id }}__hero-title {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    color: var(--gch-heading);
    font-size: clamp(24px, 3.2vw, 42px);
    line-height: 1.18;
    margin: 0;
    letter-spacing: -0.005em;
    text-transform: none;
  }

  .grimmie-care-hero-{{ section_id }}__hero-body {
    font-family: var(--font-body--family);
    color: var(--gch-text);
    font-weight: 400;
    font-size: clamp(13px, 1vw, 15px);
    line-height: 1.6;
    margin: 0;
    max-width: 380px;
    text-transform: none;
  }

  @media (max-width: 640px) {
    .grimmie-care-hero-{{ section_id }} {
      padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
    .grimmie-care-hero-{{ section_id }}__hero {
      aspect-ratio: 12 / 5;
      margin-top: -{{ section.settings.padding_top | times: 0.7 | round }}px;
    }
    .grimmie-care-hero-{{ section_id }}__hero-content {
      padding: 16px 20px;
    }
  }
</style>

<section
  class="grimmie-care-hero-{{ section_id }}"
  aria-label="{{ section.settings.aria_label | default: 'Cura del prodotto' | escape }}"
>
  <div class="grimmie-care-hero-{{ section_id }}__hero">
    <div class="grimmie-care-hero-{{ section_id }}__hero-image">
      {%- if hero_image != blank -%}
        {{ hero_image | image_url: width: 2400 | image_tag: alt: hero_image_alt, loading: 'eager', widths: '720,960,1200,1600,2000,2400', sizes: '100vw' }}
      {%- else -%}
        <svg class="placeholder" viewBox="0 0 160 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <rect x="0" y="0" width="160" height="60" fill="currentColor" opacity="0.4"/>
        </svg>
      {%- endif -%}
    </div>
    <div class="grimmie-care-hero-{{ section_id }}__hero-content">
      <div class="grimmie-care-hero-{{ section_id }}__hero-text">
        {%- if eyebrow != blank -%}
          <p class="grimmie-care-hero-{{ section_id }}__eyebrow">{{ eyebrow | escape }}</p>
        {%- endif -%}
        {%- if hero_heading != blank -%}
          <h1 class="grimmie-care-hero-{{ section_id }}__hero-title">{{ hero_heading | newline_to_br }}</h1>
        {%- endif -%}
        {%- if hero_text != blank -%}
          <p class="grimmie-care-hero-{{ section_id }}__hero-body">{{ hero_text | newline_to_br }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Grimmie Care Hero",
  "tag": "section",
  "class": "grimmie-care-hero-section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "CURA DEL PRODOTTO" },
    { "type": "textarea", "id": "hero_heading", "label": "Title", "info": "Line breaks preserved.", "default": "Come prenderti\ncura di Alma" },
    { "type": "textarea", "id": "hero_text", "label": "Body text", "default": "Alma si prende cura di te custodendo i tuoi prodotti di bellezza.\nQui ti insegniamo a prenderti cura di Alma." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_image_alt", "label": "Hero image alt text", "default": "Grimmie Alma pouch" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#F7F1EE" },
    { "type": "color", "id": "secondary_background_color", "label": "Hero background", "default": "#F1EBE6" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#6E5F59" },
    { "type": "color", "id": "text_color", "label": "Body text", "default": "#6E5F59" },
    { "type": "color", "id": "accent_color", "label": "Accent (eyebrow)", "default": "#C99696" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 48 },

    { "type": "header", "content": "Accessibility" },
    { "type": "text", "id": "aria_label", "label": "Section aria-label", "default": "Cura del prodotto" }
  ],
  "presets": [
    { "name": "Grimmie Care Hero", "category": "Grimmie" }
  ]
}
{% endschema %}
