# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Shopify
# Used to verify HMAC signatures on incoming webhooks.
# Get this from Shopify admin → Settings → Notifications → Webhooks → "Signing secret"
# OR if using a custom app: from the app credentials in Shopify Admin.
SHOPIFY_WEBHOOK_SECRET=replace-with-shopify-signing-secret

# Optional: shop domain (e.g. grimmie.myshopify.com) — used only for logging context.
SHOPIFY_SHOP_DOMAIN=grimmie.myshopify.com
